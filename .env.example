# Copy this file to .env.local and fill in real secrets on your machine.
# Do not commit .env.local because it contains private API keys.

# Google Gemini for text consultation only.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:3000

# SMTP gửi mã OTP (Gmail: dùng App Password, không dùng mật khẩu Gmail thường)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password
MAIL_FROM=Mạch Nhà <your_email@gmail.com>

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=machnha
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Optional bank webhook
PAYMENT_WEBHOOK_SECRET=your_random_webhook_secret

# Frontend
REACT_APP_API_URL=http://localhost:3001
