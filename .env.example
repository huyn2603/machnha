# Copy this file to .env.local and fill in real secrets on your machine.
# Do not commit .env.local because it contains private API keys.

# Google Gemini for text consultation only.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta

# Backend
PORT=3001
# Local: http://localhost:3000
# Production example: https://machnha.vn,https://www.machnha.vn
CORS_ORIGIN=http://localhost:3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=machnha
DB_SSL=false
DB_CONNECTION_LIMIT=10

# Optional bank webhook
PAYMENT_WEBHOOK_SECRET=

# Frontend
# Local: http://localhost:3001
# Production example: https://api.machnha.vn
REACT_APP_API_URL=http://localhost:3001
