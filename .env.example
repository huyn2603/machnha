# Copy this file to .env.local and fill in real secrets on your machine.
# Do not commit .env.local because it contains private tokens.

# Hugging Face image generation for AI try-on
HF_TOKEN=
HF_API_BASE=https://router.huggingface.co
HF_PROVIDER=fal-ai
HF_PROVIDERS=fal-ai,replicate,hf-inference
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
HF_IMAGE_TO_IMAGE_MODEL=black-forest-labs/FLUX.2-dev

# Optional Gemini config for AI text consultation
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
