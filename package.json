{
  "name": "machnha",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18 <23",
    "npm": ">=9"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.363.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "scripts": {
    "start": "cross-env NODE_NO_WARNINGS=1 concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd frontend && node ../node_modules/react-scripts/bin/react-scripts.js start",
    "backend": "node backend/server.js",
    "backend:seed": "node backend/scripts/seed.js",
    "backend:sql": "node backend/scripts/generate-sql.js",
    "build": "cd frontend && node ../node_modules/react-scripts/bin/react-scripts.js build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
